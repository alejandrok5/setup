# ============================================================================
# dunstrc — notification daemon LAYOUT.
#
# LAYOUT only (geometry, font, timeouts, behavior). The COLORS live in
# dunstrc.d/catppuccin.conf, a Catppuccin palette written by ~/setup/apply-theme.sh
# from ~/setup/dunst/themes/. Same split as polybar (config.ini = layout,
# colors.ini = palette) and i3.
#
# dunst loads this file first, then dunstrc.d/*.conf in alphabetical order, with
# later keys overriding earlier ones — so the palette drop-in's colors win over
# anything here. Do NOT set background/foreground/frame_color in this file or the
# two will fight (the drop-in wins, but it's confusing).
#
# A copy of this file is vendored at ~/setup/dunst/dunstrc; apply-theme.sh
# installs it to ~/.config/dunst/dunstrc only if absent and never overwrites your
# edits. Edit ~/.config/dunst/dunstrc for live changes.
#
# Font is MesloLGS Nerd Font to match polybar; glyphs in notification text
# (e.g. bluetooth/network icons) render from the same Nerd Font set.
# ============================================================================

[global]
    monitor = 0
    follow = mouse

    # Geometry: top-right, nudged down so it clears the polybar (height 28pt).
    width = (0, 360)
    height = (0, 300)
    origin = top-right
    offset = (12, 44)
    scale = 0
    notification_limit = 5

    # Progress bar (volume/brightness OSD-style notifications).
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 360

    # Frame + separators (colors come from the palette drop-in).
    frame_width = 2
    gap_size = 6
    separator_height = 2
    separator_color = frame
    corner_radius = 8

    padding = 12
    horizontal_padding = 14
    text_icon_padding = 10

    # Text.
    font = MesloLGS Nerd Font 10
    line_height = 2
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    word_wrap = yes
    ellipsize = middle
    show_age_threshold = 60
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    # Icons.
    enable_recursive_icon_lookup = true
    icon_theme = "Papirus-Dark, Adwaita"
    icon_position = left
    min_icon_size = 24
    max_icon_size = 48

    # Behavior.
    sticky_history = yes
    history_length = 20
    dmenu = /usr/bin/rofi -dmenu -p dunst
    browser = /usr/bin/xdg-open
    always_run_script = true
    title = Dunst
    class = Dunst
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    timeout = 5

[urgency_normal]
    timeout = 8

[urgency_critical]
    timeout = 0
