# i3 config file (v4)
#
# Please see https://i3wm.org/docs/userguide.html for a complete reference!

set $mod Mod4
for_window [class="^.*"] border pixel 2
gaps inner 15

# include ~/.config/i3/catppuccin-mocha
include ~/.config/i3/colors.conf


# Font for window titles. Will also be used by the bar unless a different font
# is used in the bar {} block below.
font pango:MesloLGS Nerd Font 12

# This font is widely installed, provides lots of unicode glyphs, right-to-left
# text rendering and scalability on retina/hidpi displays (thanks to pango).
#font pango:DejaVu Sans Mono 8

# HiDPI: 2880x1800 mode + 1.25x fractional scaling (via Xft.dpi=120), matching
# GNOME's 2304x1440 desktop. Env-var scaling + the eDP-1 mode live in
# ~/.xprofile; these run regardless of whether the DM sourced it, idempotent.
# autorandr applies the matching saved layout (mobile/docked), else extends
# horizontally; its system udev hook does the same automatically on hotplug.
exec_always --no-startup-id autorandr --change --default mobile
exec_always --no-startup-id xrdb -merge ~/.Xresources

# Touchpad: natural (inverted) scroll, tap-to-click, two-finger = right click.
exec_always --no-startup-id ~/.config/i3/scripts/touchpad.sh

# Desktop wallpaper (feh --bg-fill ~/.config/i3/wallpaper.jpg).
exec_always --no-startup-id ~/.config/i3/scripts/wallpaper.sh

# Compositor: enables window transparency (e.g. Alacritty opacity). `exec` (not
# exec_always) so an in-place i3 restart doesn't spawn a second instance.
exec --no-startup-id picom --config ~/.config/picom.conf

# Status bar: polybar (replaces i3bar). launch.sh kills any running instance
# and resolves the CPU temp sensor before relaunching, so exec_always is safe
# across in-place i3 restarts (no duplicate bars). Themed via ~/.config/polybar.
exec_always --no-startup-id ~/.config/polybar/launch.sh

# Start XDG autostart .desktop files using dex. See also
# https://wiki.archlinux.org/index.php/XDG_Autostart
exec --no-startup-id dex --autostart --environment i3

# The combination of xss-lock, nm-applet and pactl is a popular choice, so
# they are included here as an example. Modify as you see fit.

# xss-lock grabs a logind suspend inhibit lock and will use i3lock to lock the
# screen before suspend. Use loginctl lock-session to lock your screen.
exec --no-startup-id xss-lock --transfer-sleep-lock -- ~/.config/i3/scripts/lock.sh

# Pre-build the wallpaper lock background (djpeg -> PNG) so the first lock is
# instant. Cheap: lock.sh --prepare only rebuilds if the wallpaper changed.
exec --no-startup-id ~/.config/i3/scripts/lock.sh --prepare

# NetworkManager is the most popular way to manage wireless networks on Linux,
# and nm-applet is a desktop environment-independent system tray GUI for it.
exec --no-startup-id nm-applet

# blueman-applet: Bluetooth tray icon + manager GUI (the Bluetooth counterpart
# to nm-applet). Docks into the polybar tray; right-click for devices/settings.
exec --no-startup-id blueman-applet

# Refresh i3status after changes (kept for the status bar).
set $refresh_i3status killall -SIGUSR1 i3status

# Media keys (GNOME-like): volume/brightness/mic with an on-screen OSD,
# plus media transport keys. Handled by ~/.config/i3/scripts/osd.sh.
set $osd ~/.config/i3/scripts/osd.sh
bindsym XF86AudioRaiseVolume  exec --no-startup-id $osd vol-up && $refresh_i3status
bindsym XF86AudioLowerVolume  exec --no-startup-id $osd vol-down && $refresh_i3status
bindsym XF86AudioMute         exec --no-startup-id $osd vol-mute && $refresh_i3status
bindsym XF86AudioMicMute      exec --no-startup-id $osd mic-mute && $refresh_i3status

# Brightness
bindsym XF86MonBrightnessUp   exec --no-startup-id $osd bri-up
bindsym XF86MonBrightnessDown exec --no-startup-id $osd bri-down

# Media transport
bindsym XF86AudioPlay  exec --no-startup-id $osd play
bindsym XF86AudioPause exec --no-startup-id $osd play
bindsym XF86AudioNext  exec --no-startup-id $osd next
bindsym XF86AudioPrev  exec --no-startup-id $osd prev
bindsym XF86AudioStop  exec --no-startup-id $osd stop

# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

# move tiling windows via drag & drop by left-clicking into the title bar,
# or left-clicking anywhere into the window while holding the floating modifier.
tiling_drag modifier titlebar

# start a terminal
bindsym $mod+Return exec alacritty
# i3-sensible-terminal

# start the Brave web browser
# --force-device-scale-factor=1.25 pins Brave to GNOME's 1.25x; without it
# Chromium auto-detection can overshoot and oversize the UI.
bindsym $mod+b exec --no-startup-id brave-browser
# --force-device-scale-factor=1.25

# Spotify on workspace 10. The assign rule pins its window to ws10; the
# scripted bind switches there, launches it if needed, and starts playback.
assign [class="Spotify"] number 10
bindsym $mod+s exec --no-startup-id ~/.config/i3/scripts/spotify.sh

# File manager: yazi in an Alacritty window (replaces ranger). yazi lives in
# ~/.local/bin, which is on i3's PATH via ~/.profile.
bindsym $mod+y exec --no-startup-id alacritty -e yazi

# Claude Code in an Alacritty window, with permission prompts skipped
# (--dangerously-skip-permissions). claude is in ~/.local/bin (on i3's PATH).
# $claude_dir = where it opens; set to your project dir once cloned (e.g.
# set $claude_dir $HOME/code/myrepo). Defaults to home for now.
set $claude_dir $HOME
bindsym $mod+c exec --no-startup-id alacritty --working-directory $claude_dir -e claude --dangerously-skip-permissions

# (re)detect & arrange monitors — manual fallback for dock/undock
bindsym $mod+p exec --no-startup-id autorandr --change --default mobile

# kill focused window
# bindsym $mod+Shift+q kill
bindsym $mod+q kill

# App launcher: rofi (replaces dmenu_run). Shows .desktop apps with Papirus
# icons; Tab switches to the window-switcher mode. Themed Catppuccin macchiato
# (mauve accent) via ~/.config/rofi/config.rasi — see ~/setup apply-theme.sh.
bindsym $mod+d exec --no-startup-id rofi -show drun

# change focus
bindsym $mod+j focus left
bindsym $mod+k focus down
bindsym $mod+l focus up
bindsym $mod+semicolon focus right

# alternatively, you can use the cursor keys:
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# move focused window
bindsym $mod+Shift+j move left
bindsym $mod+Shift+k move down
bindsym $mod+Shift+l move up
bindsym $mod+Shift+semicolon move right

# alternatively, you can use the cursor keys:
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# split in horizontal orientation
bindsym $mod+h split h

# split in vertical orientation
bindsym $mod+v split v

# enter fullscreen mode for the focused container
bindsym $mod+f fullscreen toggle

# change container layout (tabbed, toggle split). NOTE: $mod+s is repurposed to
# launch Spotify (see the Spotify binding near the Brave launcher above); use
# $mod+w (tabbed) and $mod+e (toggle split) for layouts.
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# toggle tiling / floating
bindsym $mod+Shift+space floating toggle

# change focus between tiling / floating windows
bindsym $mod+space focus mode_toggle

# focus the parent container
bindsym $mod+a focus parent

# focus the child container
#bindsym $mod+d focus child

# Define names for default workspaces for which we configure key bindings later on.
# We use variables to avoid repeating the names in multiple places.
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# reload the configuration file
bindsym $mod+Shift+c reload
# restart i3 inplace (preserves your layout/session, can be used to upgrade i3)
bindsym $mod+Shift+r restart
# exit i3 (logs you out of your X session)
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -B 'Yes, exit i3' 'i3-msg exit'"
# Power menu: same rofi menu as the polybar power button (lock/suspend/logout/reboot/shutdown).
bindsym $mod+Escape exec --no-startup-id ~/.config/polybar/scripts/powermenu.sh

# resize window (you can also use the mouse for that)
mode "resize" {
        # These bindings trigger as soon as you enter the resize mode

        # Pressing left will shrink the window’s width.
        # Pressing right will grow the window’s width.
        # Pressing up will shrink the window’s height.
        # Pressing down will grow the window’s height.
        bindsym j resize shrink width 10 px or 10 ppt
        bindsym k resize grow height 10 px or 10 ppt
        bindsym l resize shrink height 10 px or 10 ppt
        bindsym semicolon resize grow width 10 px or 10 ppt

        # same bindings, but for the arrow keys
        bindsym Left resize shrink width 10 px or 10 ppt
        bindsym Down resize grow height 10 px or 10 ppt
        bindsym Up resize shrink height 10 px or 10 ppt
        bindsym Right resize grow width 10 px or 10 ppt

        # back to normal: Enter or Escape or $mod+r
        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}

bindsym $mod+r mode "resize"

# rotate the external monitor. "auto" targets the first connected non-primary
# output (the external). Arrow = orientation: Up=upright, Down=upside-down,
# Left/Right=portrait. rotate.sh also re-applies wallpaper + polybar for the
# new geometry, which a bare `xrandr --rotate` does not.
mode "rotate" {
        bindsym Up     exec --no-startup-id ~/.config/i3/scripts/rotate.sh auto normal,   mode "default"
        bindsym Down   exec --no-startup-id ~/.config/i3/scripts/rotate.sh auto inverted, mode "default"
        bindsym Left   exec --no-startup-id ~/.config/i3/scripts/rotate.sh auto left,     mode "default"
        bindsym Right  exec --no-startup-id ~/.config/i3/scripts/rotate.sh auto right,    mode "default"

        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+o mode "default"
}
bindsym $mod+o mode "rotate"

# The status bar is polybar, not i3bar — launched above via
# ~/.config/polybar/launch.sh and themed from ~/.config/polybar (config.ini =
# layout, colors.ini = Catppuccin palette set by ~/setup/apply-theme.sh).
